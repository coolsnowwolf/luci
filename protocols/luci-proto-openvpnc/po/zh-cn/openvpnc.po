#: luasrc/model/network/proto_openvpnc.lua:6
msgid "OpenVPN Client"
msgstr "OpenVPN 客户端"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:71
msgid "File saved to"
msgstr "文件已保存到"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:81
msgid "OpenVPN configuration"
msgstr "OpenVPN 配置"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:82
msgid "Choose which imported .ovpn file should be used by this interface."
msgstr "选择此接口要使用的已导入 .ovpn 配置文件。"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:84
msgid "-- please choose --"
msgstr "-- 请选择 --"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:110
msgid "Please upload or choose an .ovpn file"
msgstr "请上传或选择一个 .ovpn 文件"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:114
msgid "Selected .ovpn file does not exist"
msgstr "所选的 .ovpn 文件不存在"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:124
msgid "Upload .ovpn file"
msgstr "上传 .ovpn 文件"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:125
msgid "Upload files into the dedicated profile directory, then choose one from the list above."
msgstr "先将文件上传到专用配置目录，再从上方列表中选择一个配置文件。"

#: luasrc/view/openvpnc/upload.htm:3
msgid "Upload"
msgstr "上传"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:130
msgid "Username"
msgstr "用户名"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:131
msgid "If the selected profile uses auth-user-pass, a matching .auth file will be generated automatically from these credentials."
msgstr "如果所选配置使用 auth-user-pass，将根据这里填写的凭据自动生成对应的 .auth 文件。"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:134
msgid "Password"
msgstr "密码"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:138
msgid "Allow custom DNS servers"
msgstr "允许自定义 DNS 服务器"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:139
msgid "When enabled, the DNS servers entered below will be added to this interface even if the OpenVPN server does not push any DNS settings."
msgstr "启用后，即使 OpenVPN 服务端没有下发 DNS 设置，下方填写的 DNS 服务器也会被加入到此接口中。"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:143
msgid "Custom DNS servers"
msgstr "自定义 DNS 服务器"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:144
msgid "Enter one or more DNS server addresses separated by spaces or commas, for example: 1.1.1.1,8.8.8.8"
msgstr "输入一个或多个 DNS 服务器地址，使用空格或逗号分隔，例如：1.1.1.1,8.8.8.8"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:149
msgid "Allow extra route networks"
msgstr "允许附加路由网段"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:150
msgid "When enabled, the custom route networks entered below will be appended after the route networks pushed by the OpenVPN server."
msgstr "启用后，下方填写的自定义路由网段会追加到 OpenVPN 服务端下发的路由网段之后。"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:154
msgid "Extra route networks"
msgstr "附加路由网段"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:155
msgid "Enter one or more IPv4 CIDR networks separated by spaces or commas, for example: 10.0.0.0/24,172.16.10.0/24"
msgstr "输入一个或多个 IPv4 CIDR 网段，使用空格或逗号分隔，例如：10.0.0.0/24,172.16.10.0/24"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:160
msgid "Resolve specific domains via custom DNS"
msgstr "通过自定义 DNS 解析指定域名"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:161
msgid "When enabled, dnsmasq will forward the domains entered below to the custom DNS servers through /tmp/dnsmasq.d/ovpnc.conf."
msgstr "启用后，dnsmasq 会通过 /tmp/dnsmasq.d/ovpnc.conf 将下方填写的域名转发到自定义 DNS 服务器。"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:166
msgid "Domains resolved by custom DNS"
msgstr "由自定义 DNS 解析的域名"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:167
msgid "Enter one or more domains separated by spaces or commas, for example: corp.example.com"
msgstr "输入一个或多个域名，使用空格或逗号分隔，例如：corp.example.com"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:172
msgid "Authentication file"
msgstr "认证文件"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:182
msgid "Override MTU"
msgstr "覆盖 MTU"

#: luasrc/model/cbi/admin_network/proto_openvpnc.lua:186
msgid "Stored profile path"
msgstr "已保存的配置文件路径"
